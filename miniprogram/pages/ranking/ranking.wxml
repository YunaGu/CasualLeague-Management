<view class="container">
  <view class="empty-state" wx:if="{{!currentTournament}}">
    <text class="icon">🏆</text>
    <text class="text">暂无赛事，请先创建</text>
  </view>

  <block wx:if="{{currentTournament}}">
    <view class="group-section" wx:for="{{groups}}" wx:key="name">
      <view class="group-title">{{item.name === '总榜' ? item.name : item.name + ' 组'}}</view>
      <view class="card table-card">
        <!-- 表头 -->
        <view class="table-header">
          <text class="col-rank">#</text>
          <text class="col-team">球队</text>
          <text class="col-stat">赛</text>
          <text class="col-stat">胜</text>
          <text class="col-stat">平</text>
          <text class="col-stat">负</text>
          <text class="col-stat">进</text>
          <text class="col-stat">失</text>
          <text class="col-stat">净</text>
          <text class="col-points">积分</text>
        </view>
        <!-- 表格内容 -->
        <view class="table-row {{index < qualifiedCount ? 'qualified' : ''}}" wx:for="{{item.teams}}" wx:for-item="team" wx:for-index="index" wx:key="teamId">
          <text class="col-rank">{{index + 1}}</text>
          <text class="col-team">{{team.teamName}}</text>
          <text class="col-stat">{{team.played}}</text>
          <text class="col-stat">{{team.won}}</text>
          <text class="col-stat">{{team.drawn}}</text>
          <text class="col-stat">{{team.lost}}</text>
          <text class="col-stat">{{team.goalsFor}}</text>
          <text class="col-stat">{{team.goalsAgainst}}</text>
          <text class="col-stat {{team.goalDifference > 0 ? 'positive' : team.goalDifference < 0 ? 'negative' : ''}}">{{team.goalDifference}}</text>
          <text class="col-points">{{team.points}}</text>
        </view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend" wx:if="{{qualifiedCount > 0}}">
      <view class="legend-item">
        <view class="legend-dot qualified-dot"></view>
        <text>晋级区</text>
      </view>
    </view>

    <view class="card rules-card" wx:if="{{advancementRules.length > 0}}">
      <view class="rules-title">{{rulesTitle}}</view>
      <view class="rule-item" wx:for="{{advancementRules}}" wx:key="index">
        <text class="rule-index">{{index + 1}}.</text>
        <text class="rule-text">{{item}}</text>
      </view>
    </view>
  </block>
</view>
