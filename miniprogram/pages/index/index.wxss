.tournament-header {
  padding: 40rpx 30rpx;
}

.tournament-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.tournament-stage {
  display: inline-block;
}

.team-count {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.count-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1AAD19;
}

.count-label {
  font-size: 22rpx;
  color: #999;
}

/* 比赛项目 */
.match-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.match-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.match-teams {
  display: flex;
  align-items: center;
  justify-content: center;
}

.team-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}

.team-name.home {
  text-align: right;
  padding-right: 20rpx;
}

.team-name.away {
  text-align: left;
  padding-left: 20rpx;
}

.match-score {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 120rpx;
  justify-content: center;
}

.match-score.pending {
  color: #999;
  font-size: 26rpx;
}

.score {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.score-sep {
  font-size: 28rpx;
  color: #999;
}

.match-meta {
  text-align: center;
  margin-top: 8rpx;
}

/* 赛事列表 */
.tournament-list {
  margin-top: 10rpx;
}

.tournament-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.tournament-item.active {
  background: #e8f5e9;
}

.tournament-item-name {
  font-size: 28rpx;
  color: #333;
}

.tournament-item-count {
  font-size: 24rpx;
  color: #999;
}
