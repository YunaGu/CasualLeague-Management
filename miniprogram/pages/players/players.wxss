/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1AAD19;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #1AAD19;
  border-radius: 2rpx;
}

/* 射手榜 */
.scorer-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.scorer-item:last-child {
  border-bottom: none;
}

.scorer-rank {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  color: #999;
  background: #f5f5f5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.scorer-rank.top-1 {
  background: #ffd700;
  color: #fff;
}

.scorer-rank.top-2 {
  background: #c0c0c0;
  color: #fff;
}

.scorer-rank.top-3 {
  background: #cd7f32;
  color: #fff;
}

.scorer-info {
  flex: 1;
}

.edit-name-btn {
  font-size: 22rpx;
  color: #1565c0;
  background: #e3f2fd;
  border-radius: 8rpx;
  padding: 6rpx 14rpx;
  margin-right: 12rpx;
}

.scorer-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.scorer-team {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.scorer-goals {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.goals-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1AAD19;
}

.goals-label {
  font-size: 22rpx;
  color: #999;
}

/* 纪律统计 */
.discipline-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.discipline-item:last-child {
  border-bottom: none;
}

.discipline-rank {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  color: #999;
  background: #f5f5f5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.discipline-info {
  flex: 1;
}

.discipline-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.discipline-team {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.discipline-cards {
  display: flex;
  gap: 12rpx;
}

.card-badge {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-badge.yellow {
  background: #fff8e1;
}

.card-badge.red {
  background: #fbe9e7;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 82%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  padding: 28rpx 20rpx 16rpx;
}

.modal-body {
  padding: 16rpx 24rpx 26rpx;
}

.name-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  border: none;
  border-radius: 0;
  margin: 0;
  padding: 18rpx 0;
  font-size: 28rpx;
}

.btn-cancel {
  color: #666;
  background: #fff;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #1AAD19;
  background: #fff;
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}
