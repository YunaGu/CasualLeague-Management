/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1AAD19;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #1AAD19;
  border-radius: 2rpx;
}

/* 轮次标题 */
.round-section {
  margin-bottom: 20rpx;
}

.round-title {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  margin-bottom: 10rpx;
  padding-left: 10rpx;
}

/* 比赛项 */
.schedule-match {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.schedule-match:last-child {
  border-bottom: none;
}

.match-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.team-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.team-name.home {
  text-align: right;
  padding-right: 20rpx;
  color: #1565c0;
}

.team-name.away {
  text-align: left;
  padding-left: 20rpx;
  color: #c62828;
}

.score-box {
  min-width: 140rpx;
  text-align: center;
}

.score {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.score.live {
  color: #e53935;
}

.vs {
  font-size: 26rpx;
  color: #ccc;
  font-weight: 500;
}

.match-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 10rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
  word-break: keep-all;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
}

.group-label {
  font-size: 22rpx;
  color: #999;
}

.schedule-extra {
  margin-top: 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: #666;
}

.schedule-extra.penalty {
  color: #2e7d32;
  font-weight: 600;
}

.event-preview {
  margin-top: 10rpx;
  padding: 10rpx 14rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.event-preview-title {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.event-preview-item {
  font-size: 22rpx;
  color: #444;
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.event-preview-item:last-child {
  margin-bottom: 0;
}

.event-icon {
  width: 28rpx;
  text-align: center;
}

.event-side {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.event-side.home {
  color: #1565c0;
  background: #e3f2fd;
}

.event-side.away {
  color: #c62828;
  background: #fce4ec;
}

.event-team {
  color: #333;
}

.event-player {
  color: #666;
}

.event-minute {
  color: #999;
  margin-left: auto;
}

.event-preview-more {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #999;
}

.match-actions {
  margin-top: 10rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  background: #eceff1;
  color: #455a64;
}

.action-btn.start {
  background: #e8f5e9;
  color: #1b5e20;
}

.action-btn.finish {
  background: #ffebee;
  color: #b71c1c;
}

/* 淘汰赛标签 */
.knockout-label {
  font-size: 24rpx;
  color: #1AAD19;
  font-weight: 600;
  text-align: center;
  margin-bottom: 10rpx;
}
