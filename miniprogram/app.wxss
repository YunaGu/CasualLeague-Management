/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: #333;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 20rpx 30rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background: #1AAD19;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #1AAD19;
  border: 2rpx solid #1AAD19;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  font-size: 30rpx;
  color: #999;
  text-align: center;
}

/* 标签 */
.tag {
  font-size: 22rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  white-space: nowrap;
  word-break: keep-all;
}

.tag-green {
  background: #e8f5e9;
  color: #1AAD19;
}

.tag-yellow {
  background: #fff8e1;
  color: #f9a825;
}

.tag-red {
  background: #fbe9e7;
  color: #e53935;
}

.tag-blue {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-gray {
  background: #f5f5f5;
  color: #999;
}

/* Flex 工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}
